# Solana
SOLANA_RPC=https://api.mainnet-beta.solana.com
SOLANA_WALLET_ADDRESS=
SOLANA_WALLET_PRIVATE_KEY=
LPS_MINT_ADDRESS=

# Upstream backtest service
BACKTEST_UPSTREAM=http://k-solana-backtest:8000

# x402
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# Pricing (LPS amounts charged to users)
SIGNAL_PRICE=0.10
REFRESH_PRICE=0.50
RECEIPT_PRICE=0.05
DEVICE_REGISTER_PRICE=0.01
WIZARD_FOLLOW_PRICE=0.10
WIZARD_SIGNAL_PRICE=2.00

# laconicd
LACONICD_GQL=http://laconicd:9473/api
ENCRYPTION_KEY=

# Firebase
FIREBASE_SERVICE_ACCOUNT=/config/service-account.json

# Apple IAP (App Store Server API v2)
APPLE_KEY_ID=
APPLE_ISSUER_ID=
APPLE_PRIVATE_KEY_PATH=/config/apple-key.p8
APPLE_BUNDLE_ID=
APPLE_ENVIRONMENT=production

# Scheduler
SIGNAL_CYCLE_INTERVAL_HOURS=24
